{
  "name": "@luminalog/logger",
  "version": "0.1.0",
  "description": "LuminaLog SDK - Privacy-first logging with AI-powered debugging",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test dist/**/*.test.js",
    "example:privacy": "npx tsx example/privacy-test.ts",
    "example:edtech": "npx tsx example/edtech-test.ts",
    "example:fintech": "npx tsx example/fintech-test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "logging",
    "observability",
    "privacy",
    "pii",
    "debugging",
    "luminalog"
  ],
  "author": "LuminaLog Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohses777/luminalog-node.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.966.0"
  }
}